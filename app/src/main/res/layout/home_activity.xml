<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.HomeActivity"
    android:orientation="vertical"
    android:id="@+id/home_drawer_layout"
    android:background="@color/twilightGradient">

    <com.google.android.material.navigation.NavigationView
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:id="@+id/home_navigation_view"
        app:menu="@menu/main_navigation_menu"
        app:headerLayout="@layout/main_navigation_header"
        android:layout_gravity="start"
        android:background="@color/twilightGradient"/>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <include
            layout="@layout/main_toolbar"
            android:id="@+id/home_toolbar"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:id="@+id/anchor"
            android:layout_below="@+id/home_toolbar"
            android:orientation="horizontal"
            android:padding="10dp"
            android:elevation="@dimen/card_elevation">

            <TextView
                android:padding="10dp"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="@string/believer_name"
                android:textColor="@color/white"
                android:shadowColor="@color/primary_blue"
                android:shadowDy="1"
                android:shadowDx="1"
                android:shadowRadius="2"
                android:gravity="center_vertical"
                android:textSize="35sp"
                android:textStyle="bold"/>

            <ImageView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:src="@drawable/png"
                android:contentDescription="@string/content_description"/>

        </LinearLayout>


        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@+id/anchor"
            android:id="@+id/home_scroll_view"
            android:fillViewport="true"
            android:layoutDirection="rtl">

            <androidx.recyclerview.widget.RecyclerView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/home_recycler"/>

        </ScrollView>

    </RelativeLayout>

</androidx.drawerlayout.widget.DrawerLayout>