<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="10dp"
    android:layoutDirection="rtl"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        android:text="@string/zkah"
        android:padding="7dp"
        android:gravity="start"
        android:textSize="33sp"
        android:textStyle="bold"
        android:id="@+id/zkah"/>

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scaleType="fitCenter"
        android:src="@drawable/zkah"
        android:id="@+id/zkah_image"
        android:padding="10dp"
        android:contentDescription="@string/image_resource" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight=".8"
        android:fillViewport="true"
        android:id="@+id/arkan_zkah_scroll">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:text="@string/zkah_info"
            android:padding="7dp"
            android:textAlignment="viewStart"
            android:textSize="20sp"
            android:id="@+id/zkah_info"/>

    </ScrollView>
</LinearLayout>