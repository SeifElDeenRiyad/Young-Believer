<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.AsmaaAllahHosnaActivity"
    android:orientation="vertical"
    android:id="@+id/asmaa_allah_drawer_layout"
    android:background="@color/twilightGradient">

    <com.google.android.material.navigation.NavigationView
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:id="@+id/asmaa_allah_navigation_view"
        app:menu="@menu/main_navigation_menu"
        app:headerLayout="@layout/main_navigation_header"
        android:layout_gravity="start"
        android:background="@color/twilightGradient"/>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <include
            layout="@layout/main_toolbar"
            android:id="@+id/asmaa_allah_toolbar"/>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/asmaa_allah_toolbar"
            android:id="@+id/asmaa_allah_page"
            android:layoutDirection="rtl">

            <androidx.recyclerview.widget.RecyclerView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:id="@+id/asmaa_allah_recycler"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                app:cardElevation="@dimen/card_elevation"
                android:visibility="gone"
                android:id="@+id/card_view">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/asm_allah_meaning"
                    android:background="@color/primary_blue"
                    android:textSize="24sp"
                    android:textColor="@color/white"
                    android:padding="10dp"
                    android:textAlignment="center"/>

            </com.google.android.material.card.MaterialCardView>

            <View
                android:id="@+id/overlay_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#88000000"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true"/>

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fab_asmaa_allah"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/dark_blue"
                android:layout_gravity="top|start"
                android:elevation="@dimen/card_elevation"
                android:src="@drawable/outline_close_white_48"
                android:layout_margin="16dp"
                android:visibility="gone"
                android:contentDescription="@string/x" />

        </FrameLayout>
    </RelativeLayout>
</androidx.drawerlayout.widget.DrawerLayout>